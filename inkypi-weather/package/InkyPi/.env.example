# InkyPi local API keys
# Copy this file to .env or run:
#   python3 install/configure_api_keys.py --env-file .env
#
# Full key list with registration URLs:
#   python3 install/configure_api_keys.py --list
#
# Do not commit real API keys.

# Weather / Mini Weather
# Get key: https://home.openweathermap.org/api_keys
# OPEN_WEATHER_MAP_SECRET=

# OpenAI-backed AI Image, AI Text, Daily AI News, Epaper Pet
# Get key: https://platform.openai.com/api-keys
# OPEN_AI_SECRET=

# Groq-backed Daily AI News / Epaper Pet
# Get key: https://console.groq.com/keys
# GROQ_API_KEY=

# Google AI Studio / Gemini provider paths
# Get key: https://aistudio.google.com/app/apikey
# NANO_BANANA_KEY=

# NASA Astronomy Picture of the Day
# Get key: https://api.nasa.gov/
# NASA_SECRET=

# Unsplash plugin
# Get key: https://unsplash.com/developers
# UNSPLASH_ACCESS_KEY=

# GitHub plugins
# Get token: https://github.com/settings/tokens
# GITHUB_SECRET=

# Steam Profile Dashboard
# Get key: https://steamcommunity.com/dev/apikey
# STEAM_API_KEY=

# Comic covers
# Get key: https://comicvine.gamespot.com/api/
# COMIC_VINE_API_KEY=

# League of Legends info
# Get key: https://developer.riotgames.com/
# RIOT_API_KEY=

# Stock Tracker / Daily AI News market context
# Get key: https://massive.com/
# MASSIVE_API_KEY=

# Weather request safety defaults
OPENWEATHER_ONECALL_DAILY_LIMIT=900
OPENWEATHER_ONECALL_MIN_SECONDS=1800
OPENWEATHER_AUX_MIN_SECONDS=1800
OPENWEATHER_LOCATION_MIN_SECONDS=86400
