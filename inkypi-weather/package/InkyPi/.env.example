# InkyPi optional credentials and secret paths
# Copy this file to the configured runtime env path, or run:
#   python3 install/configure_api_keys.py --env-file /etc/inkypi/inkypi.env
# Do not commit real credentials.

# OpenAI - AI Image, AI Text, Daily AI News, Epaper Pet, AI Image Multiverse
# Help: https://platform.openai.com/api-keys
# Legacy aliases accepted: OPEN_AI_SECRET
# Note: OpenAI account billing may be required.
# OPENAI_API_KEY=

# Groq - Daily AI News, Epaper Pet, AI Image Multiverse
# Help: https://console.groq.com/keys
# Legacy aliases accepted: Groq_V2, GROQ_KEY
# GROQ_API_KEY=

# Google AI Studio / Gemini - AI Image Multiverse
# Help: https://aistudio.google.com/app/apikey
# Legacy aliases accepted: GOOGLE_AI_API_KEY, GEMINI_API_KEY
# NANO_BANANA_KEY=

# AI Horde - AI Image Multiverse
# Help: https://aihorde.net/register
# AI_HORDE_KEY=

# OpenWeather - Weather, Mini Weather
# Help: https://home.openweathermap.org/api_keys
# Note: One Call API 3.0 may require enabling a subscription.
# OPEN_WEATHER_MAP_SECRET=

# NASA Open APIs - Astronomy Picture of the Day
# Help: https://api.nasa.gov/
# NASA_SECRET=

# Unsplash - Unsplash
# Help: https://unsplash.com/developers
# UNSPLASH_ACCESS_KEY=

# GitHub - GitHub Contributions, GitHub Sponsors
# Help: https://github.com/settings/tokens
# Legacy aliases accepted: GITHUB_TOKEN
# GITHUB_SECRET=

# Immich - Image Album
# Help: https://immich.app/docs/features/command-line-interface/
# IMMICH_KEY=

# Steam Web API - Steam Profile Dashboard
# Help: https://steamcommunity.com/dev/apikey
# STEAM_API_KEY=

# Comic Vine - GCD Comic Covers
# Help: https://comicvine.gamespot.com/api/
# Legacy aliases accepted: COMICVINE_API_KEY, COMIC_VINE_KEY, COMICVINE_KEY, COMICVINE, COMIC_VINE, Comic_Vine_Key
# COMIC_VINE_API_KEY=

# Riot Developer Portal - League of Legends Info
# Help: https://developer.riotgames.com/
# Legacy aliases accepted: Riot_KEY, RIOT_KEY
# Note: Development keys expire; use a production key for unattended displays.
# RIOT_API_KEY=

# OpenDota - Dota Profile Dashboard
# Help: https://www.opendota.com/api-keys
# Legacy aliases accepted: OPENDOTA_KEY, OpenDota_Key
# OPENDOTA_API_KEY=

# FlightAware AeroAPI - Flight Radar
# Help: https://flightaware.com/aeroapi/portal/
# FLIGHTAWARE_API_KEY=

# OpenSky Network username - Flight Radar
# Help: https://opensky-network.org/
# OPENSKY_USERNAME=

# OpenSky Network password - Flight Radar
# Help: https://opensky-network.org/
# OPENSKY_PASSWORD=

# RapidAPI - Flight Radar, Daily Knowledge
# Help: https://rapidapi.com/hub
# Legacy aliases accepted: X_RAPIDAPI_KEY, WORLD_FUN_FACTS_API_KEY, WORLD_FUN_FACTS_KEY, Fun_Fact, FUN_FACT
# RAPIDAPI_KEY=

# Google Maps Platform - Flight Radar map background
# Help: https://console.cloud.google.com/google/maps-apis/credentials
# Legacy aliases accepted: Google_KEY, GOOGLE_KEY
# GOOGLE_MAPS_API_KEY=

# Europeana - Daily Art
# Help: https://pro.europeana.eu/page/get-api
# Legacy aliases accepted: EUROPEANA_KEY, EUROPEANA_WSKEY, EUROPEANA_APIKEY, EUROPEANA_PERSONAL_API_KEY, Europeana_API_Key, Europeana_Key, EuropeanaApiKey, EUROPEANA
# EUROPEANA_API_KEY=

# Harvard Art Museums - Daily Art
# Help: https://harvardartmuseums.org/collections/api
# Legacy aliases accepted: HARVARD_ART_MUSEUM_API_KEY, HARVARD_ART_MUSEUMS_KEY, HARVARD_ART_MUSEUM_KEY, HARVARD_ART_API_KEY, HARVARD_API_KEY, HAM_API_KEY, Harvard_Art_Museums_Key, Harvard_Art_Museum_Key, Harvard_Art_Museums_API_Key, Harvard_Art_Museum_API_Key, Harvard_Art_Key, Harverd_Key, HARVARD
# HARVARD_ART_MUSEUMS_API_KEY=

# The Movie Database - Box Office Top Movies
# Help: https://www.themoviedb.org/settings/api
# Legacy aliases accepted: TMDB_READ_ACCESS_TOKEN, TMDB_ACCESS_TOKEN, TMDB_Access_Token, THEMOVIEDB_BEARER_TOKEN
# TMDB_BEARER_TOKEN=

# The Movie Database API key - Box Office Top Movies
# Help: https://www.themoviedb.org/settings/api
# Legacy aliases accepted: THEMOVIEDB_API_KEY
# TMDB_API_KEY=

# Massive - Stock Tracker, Daily AI News market context
# Help: https://massive.com/
# Legacy aliases accepted: MASSIVE_ECONOMIC_KEY, MASSIVE_ECNOMIC_KEY, Massive_Ecnomic_Key
# MASSIVE_API_KEY=

# football-data.org - Sports Dashboard
# Help: https://www.football-data.org/client/register
# Legacy aliases accepted: FOOTBALL_DATA, FOOTBALL_DATA_KEY, FOOTBALL_DATA_TOKEN, FOOTBALLDATA_KEY, FOOTBALLDATA_TOKEN
# FOOTBALL_DATA_API_KEY=

# API-SPORTS / API-Football - Sports Dashboard
# Help: https://dashboard.api-football.com/register
# Legacy aliases accepted: APISPORTS_KEY, API_FOOTBALL_KEY, API_FPPTBALL_KEY, X_APISPORTS_KEY, WORLD_CUP_API_KEY
# API_SPORTS_KEY=

# The Odds API - Sports Dashboard odds
# Help: https://the-odds-api.com/#get-access
# Legacy aliases accepted: ODDS_API_KEY, WORLD_CUP_ODDS_API_KEY, NBA_THE_ODDS_API_KEY, NBA_ODDS_API_KEY
# THE_ODDS_API_KEY=

# Odds-API.io - Sports Dashboard odds
# Help: https://odds-api.io/
# Legacy aliases accepted: LPL_ODDS_API_IO_KEY, Odds_API_IO_KEY, ODDSAPI_IO_KEY, WORLD_CUP_ODDS_API_IO_KEY, NBA_ODDS_API_IO_KEY, NBA_ODDSAPI_IO_KEY
# ODDS_API_IO_KEY=

# Pixiv - Pixiv R-18 Ranking
# Help: https://www.pixiv.net/settings/viewing
# Legacy aliases accepted: PIXIV_COOKIE, PIXIV_SESSION
# Note: Use the PHPSESSID cookie from a logged-in Pixiv session.
# PIXIV_PHPSESSID=

# Battle.net Developer Portal - WoW Profile Dashboard
# Help: https://develop.battle.net/access/clients
# Legacy aliases accepted: BNET_CLIENT_ID, BATTLE_NET_CLIENT_ID, WOW_CLIENT_ID, WOW_KEY, WoW_Key
# BLIZZARD_CLIENT_ID=

# Battle.net Developer Portal - WoW Profile Dashboard
# Help: https://develop.battle.net/access/clients
# Legacy aliases accepted: BNET_CLIENT_SECRET, BATTLE_NET_CLIENT_SECRET, WOW_CLIENT_SECRET
# BLIZZARD_CLIENT_SECRET=

# Battle.net OAuth - WoW Profile Dashboard account mode
# Help: https://develop.battle.net/documentation/guides/using-oauth
# Legacy aliases accepted: BNET_USER_ACCESS_TOKEN, BATTLE_NET_USER_ACCESS_TOKEN, WOW_PROFILE_ACCESS_TOKEN, BLIZZARD_ACCESS_TOKEN, BNET_ACCESS_TOKEN, BATTLE_NET_ACCESS_TOKEN, WOW_ACCESS_TOKEN
# BLIZZARD_USER_ACCESS_TOKEN=

# Ticketmaster Discovery API - Ticketmaster events
# Help: https://developer.ticketmaster.com/products-and-docs/apis/getting-started/
# Legacy aliases accepted: TICKETMASTER_CONSUMER_KEY, TICKETMASTER_DISCOVERY_API_KEY, TICKETMASTER_KEY, TICKETMASTER_DISCOVERY_KEY, TM_API_KEY
# TICKETMASTER_API_KEY=

# Telegram Bot API - Telegram Digest bot mode
# Help: https://core.telegram.org/bots/tutorial
# Legacy aliases accepted: TG_BOT_TOKEN, TELEGRAM_TOKEN, TELEGRAM_DIGEST_BOT_TOKEN
# TELEGRAM_BOT_TOKEN=

# Telegram API ID - Telegram Digest account mode
# Help: https://my.telegram.org/apps
# Legacy aliases accepted: TG_API_ID, TELEGRAM_APP_ID, TELEGRAM_DIGEST_API_ID
# TELEGRAM_API_ID=

# Telegram API hash - Telegram Digest account mode
# Help: https://my.telegram.org/apps
# Legacy aliases accepted: TG_API_HASH, TELEGRAM_APP_HASH, TELEGRAM_DIGEST_API_HASH
# TELEGRAM_API_HASH=

# Telegram session file - Telegram Digest account mode
# Help: https://docs.telethon.dev/en/stable/concepts/sessions.html
# Type: path
# Legacy aliases accepted: TG_SESSION_PATH, TELEGRAM_ACCOUNT_SESSION, TELEGRAM_DIGEST_SESSION_PATH
# TELEGRAM_SESSION_PATH=

# Bambu Lab printer - Bambu Monitor
# Help: https://wiki.bambulab.com/en/general/find-sn
# Legacy aliases accepted: BAMBU_LAB_ACCESS_CODE
# BAMBU_ACCESS_CODE=

# Reddit OAuth client ID - Reddit Rule34 Hot
# Help: https://www.reddit.com/prefs/apps
# REDDIT_CLIENT_ID=

# Reddit OAuth client secret - Reddit Rule34 Hot
# Help: https://www.reddit.com/prefs/apps
# REDDIT_CLIENT_SECRET=

# Reddit OAuth refresh token - Reddit Rule34 Hot
# Help: https://github.com/reddit-archive/reddit/wiki/OAuth2
# REDDIT_REFRESH_TOKEN=

# Twitch application client ID - LiveRadar
# Help: https://dev.twitch.tv/console/apps
# TWITCH_CLIENT_ID=

# Twitch application client secret - LiveRadar
# Help: https://dev.twitch.tv/console/apps
# TWITCH_CLIENT_SECRET=

# Non-secret runtime defaults
# Weather safety throttle.
OPENWEATHER_ONECALL_DAILY_LIMIT=900
# Weather safety throttle.
OPENWEATHER_ONECALL_MIN_SECONDS=1800
# Weather safety throttle.
OPENWEATHER_AUX_MIN_SECONDS=1800
# Weather safety throttle.
OPENWEATHER_LOCATION_MIN_SECONDS=86400

# Optional browser screenshot egress allowlist
# Cloud metadata addresses remain denied for every configuration.
# Exact private hostnames allowed for browser screenshots.
# INKYPI_BROWSER_ALLOWED_HOSTS=panel.home.arpa
# Narrow private CIDRs allowed for browser screenshots.
# INKYPI_BROWSER_ALLOWED_CIDRS=192.168.1.0/24
