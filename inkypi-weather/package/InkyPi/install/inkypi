#!/usr/bin/env bash
set -Eeuo pipefail

# entry script to launch the service

export APPNAME="inkypi"
export PROGRAM_PATH=/opt/inkypi/current
export VENV_PATH="$PROGRAM_PATH/venv_inkypi"
export INKYPI_CACHE_DIR=/var/cache/inkypi
export INKYPI_DATA_DIR=/var/lib/inkypi/data

export PROJECT_DIR="$PROGRAM_PATH"
export SRC_DIR="$PROGRAM_PATH/src"

RELEASE_ID_FILE="$PROGRAM_PATH/.release-id"
if [[ ! -f "$RELEASE_ID_FILE" ]]; then
    echo "InkyPi release identity is missing: $RELEASE_ID_FILE" >&2
    exit 1
fi
IFS= read -r INKYPI_RELEASE_ID < "$RELEASE_ID_FILE"
if [[ ! "$INKYPI_RELEASE_ID" =~ ^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$ ]]; then
    echo "InkyPi release identity is invalid" >&2
    exit 1
fi
export INKYPI_RELEASE_ID

command="${1:-}"
if [[ $# -gt 0 ]]; then
    shift
fi

usage() {
    echo ""
    echo "Usage:"
    echo "  inkypi run"
    echo "  inkypi plugin <subcommand> [args]"
    echo "  inkypi admin bootstrap"
    echo "  inkypi admin recover"
    echo "  sudo inkypi update --artifact <zip> --sha256 <hash> --release-id <id>"
    echo ""
}

run_app() {
    exec "$VENV_PATH/bin/python" -u "$(realpath "$PROGRAM_PATH/src/inkypi.py")"
}

run_plugin_cli() {
    exec "$PROGRAM_PATH/cli/inkypi-plugin" "$@"
}

run_admin_cli() {
    subcommand="${1:-}"
    case "$subcommand" in
        bootstrap|recover)
            exec "$VENV_PATH/bin/python" "$PROGRAM_PATH/install/bootstrap_admin.py" "$subcommand"
            ;;
        *)
            echo "Usage: inkypi admin <bootstrap|recover>"
            exit 1
            ;;
    esac
}

run_update_cli() {
    exec /usr/local/sbin/inkypi-update "$@"
}

case "$command" in
    run)
        run_app
        ;;
    plugin)
        run_plugin_cli "$@"
        ;;
    admin)
        run_admin_cli "$@"
        ;;
    update)
        run_update_cli "$@"
        ;;
    ""|-h|--help|help)
        usage
        exit 0
        ;;
    *)
        echo "Unknown command: $command"
        usage
        exit 1
        ;;
esac
